# =================================
# Configurações do Sistema de Inventário Protheus
# =================================
# IMPORTANTE: Copie este arquivo para .env e preencha os valores reais
# NUNCA versione o arquivo .env no git

# =================================
# AMBIENTE
# =================================
# Valores: development, staging, production
ENVIRONMENT=development

# Habilitar modo debug (false em produção)
DEBUG=true

# =================================
# BANCO DE DADOS
# =================================
# Formato: postgresql://usuario:senha@host:porta/banco
DATABASE_URL=postgresql://inventario_user:ALTERAR_SENHA_AQUI@postgres:5432/inventario_protheus

# =================================
# SEGURANÇA
# =================================
# Chave secreta para JWT (gerar com: openssl rand -hex 32)
# IMPORTANTE: NUNCA use o valor padrão em produção!
SECRET_KEY=gerar-chave-256-bits-aqui-usando-openssl-rand-hex-32

# Algoritmo de criptografia JWT
ALGORITHM=HS256

# Tempo de expiração do token em minutos (480 = 8 horas)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# =================================
# API PROTHEUS
# =================================
# URL da API de sincronização Protheus
# ✅ v2.19.47: Atualizado endpoint para porta 8104
PROTHEUS_API_URL=https://apiportal.capul.com.br:8104/rest/api/INFOCLIENTES/hierarquiaMercadologica

# Credencial Base64 para autenticação (substituir pelo valor real)
# Formato: Basic base64(usuario:senha)
PROTHEUS_API_AUTH=Basic CREDENCIAL_BASE64_AQUI

# Timeout em segundos para requisições à API
PROTHEUS_API_TIMEOUT=30

# =================================
# CORS
# =================================
# Origens permitidas (separar por vírgula)
# Em produção, especificar domínios exatos
CORS_ORIGINS=http://localhost,http://localhost:8000,https://localhost:8443

# =================================
# ENDPOINTS DE TESTE
# =================================
# NUNCA habilitar em produção!
# Automaticamente desabilitado quando ENVIRONMENT=production
ENABLE_TEST_ENDPOINTS=true

# =================================
# LOGGING
# =================================
# Níveis: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =================================
# CACHE REDIS
# =================================
# URL de conexão com Redis
REDIS_URL=redis://redis:6379/0
