generated/

# Certs (dev only - DO NOT commit production certs)
nginx/certs/*.pem
nginx/certs/*.key
nginx/certs/*.crt
# Certificados ICP-Brasil / A1 (fiscal) — nunca commitar arquivos reais
*.pfx
*.p12
fiscal/backend/certs/*.pfx
fiscal/backend/certs/*.p12
# Manter estrutura dos diretorios em git mesmo sem conteudo
!nginx/certs/.gitkeep
!fiscal/backend/certs/.gitkeep

# Coverage
coverage/

# Claude Code — config local pessoal (allowlists Bash, etc.)
# Convenção .local segue o mesmo padrão de .env.*.local — config compartilhada
# fica em .claude/settings.json (se existir); local fica fora do repo.
.claude/settings.local.json
