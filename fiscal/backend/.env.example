# ============================================================
# Fiscal Backend — exemplo de variáveis de ambiente
# Copie para .env e ajuste; em produção use Docker secrets
# ============================================================

# --- Banco ---
DATABASE_URL=postgresql://capul_user:ALTERAR_SENHA@postgres:5432/capul_platform?schema=public
DB_SCHEMA=fiscal
CORE_SCHEMA=core

# --- Servidor ---
NODE_ENV=development
PORT=3002
CORS_ORIGINS=https://localhost,https://localhost:5176,http://localhost:5176

# --- JWT (compartilhado com Auth Gateway e demais módulos) ---
JWT_SECRET=ALTERAR_CHAVE_SECRETA_MINIMO_64_CARACTERES

# --- Redis (BullMQ + cache) ---
REDIS_URL=redis://redis:6379

# --- Certificado A1 do Módulo Fiscal (DEDICADO — não compartilhar com Protheus emissão) ---
# Ver mitigação 11.A do addendum v1.5
FISCAL_NFE_CERT_PATH=/app/certs/certificado-fiscal.pfx
FISCAL_MASTER_KEY=ALTERAR_CHAVE_AES_256_BITS_BASE64

# --- SEFAZ ---
FISCAL_SEFAZ_AMBIENTE=HOMOLOGACAO  # ou PRODUCAO
FISCAL_PAUSE_SYNC=false             # freio de mão global (mitigação 11.C)
FISCAL_CNPJ_CONSULENTE=00000000000000  # CNPJ da CAPUL — usado pelo NFeDistribuicaoDFe

# --- Protheus REST (compartilhado com inventario/gestao-ti) ---
PROTHEUS_API_URL=https://apiportal.capul.com.br:8104/rest/api/INFOCLIENTES
PROTHEUS_API_AUTH=Basic ALTERAR_BASE64

# --- MOCK do Protheus xmlFiscal (true até a reunião com time Protheus em 13/04/2026) ---
# Quando true, ProtheusXmlService usa stub em memória; quando false, chama o endpoint REST real.
FISCAL_PROTHEUS_MOCK=true

# --- SMTP corporativo (alertas consolidados) ---
SMTP_HOST=smtp.capul.com.br
SMTP_PORT=587
SMTP_USER=fiscal@capul.com.br
SMTP_PASSWORD=ALTERAR
SMTP_FROM="Plataforma Capul - Módulo Fiscal <fiscal@capul.com.br>"
FISCAL_FALLBACK_EMAIL=ti@capul.com.br

# --- Storage de XMLs (cache local opcional) ---
FISCAL_STORAGE=/app/xmls
