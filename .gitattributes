# Forçar LF para todos os arquivos de texto (evita CRLF em Linux)
* text=auto eol=lf

# Shell scripts — sempre LF (CRLF causa "invalid option" e "$'\r': command not found" no Linux)
*.sh text eol=lf

# SQL — sempre LF
*.sql text eol=lf

# Arquivos de configuração
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.env text eol=lf
*.conf text eol=lf
*.md text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.py text eol=lf
*.prisma text eol=lf
*.html text eol=lf
*.css text eol=lf

# Binários — não converter
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.p12 binary
*.pem binary
*.crt binary
*.key binary
